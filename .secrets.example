# Copy to `.secrets` and fill in real values. Never commit `.secrets`.
# Loaded by config.py at import time; values become os.environ entries.

# Moltbook social network — register an agent to get a key:
#   python3 -c "import moltbook; moltbook.register('AgentName', 'Description')"
MOLTBOOK_API_KEY=

# Telegram bot — get the token from @BotFather, the chat ID by running
# telegram_poll.py once and DM'ing the bot.  Both required for --telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
